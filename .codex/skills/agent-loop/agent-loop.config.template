# Consumer-owned agent-loop settings. Literal `key = value` lines; this file is
# parsed, never sourced. Do not embed credentials, identifiers, PHI, or user data.

# Integration branch. Leave empty to use origin/HEAD, then main.
base_branch =

# Run once inside each new issue worktree. Use an isolated frozen install; never
# symlink mutable node_modules or equivalent dependency directories.
setup_hook =

# Run after the worker, after each local review, and after fresh-base merge.
# Prefer targeted checks and avoid unbounded full-suite output.
validation_hook =

# Both review hooks are required. Each must review locally, fix confirmed
# findings, revalidate as needed, commit any fixes, and leave a clean tree.
# They must not push, open a PR, or invoke hosted AI reviewers.
claude_review_hook =
codex_review_hook =

# Optional worker override. When empty, the wrapper runs `codex exec` with the
# prompt from prompt.txt. The default worker honors the model settings below.
worker_hook =
worker_model =
worker_fallback_model =
worker_retries = 1
worker_timeout_seconds = 3600
hook_timeout_seconds = 3600
retry_on_timeout = true
retry_delay_seconds = 15

# `ready` preserves legacy open/closed dependency behavior. `merged-to-base`
# requires dependency PR merge commits to be present in origin/<base>.
dependency_gate = ready

branch_prefix = agent-loop
worktree_root = /tmp/agent-loop-worktrees
log_root = /tmp/agent-loop-logs
log_max_kb = 1024
output_max_lines = 40
